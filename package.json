{
  "name": "opengeo-data",
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc -p tsconfig.build.json",
    "start": "node dist/index.js",
    "harvest": "tsx src/harvester/run.ts --all",
    "harvest:source": "tsx src/harvester/run.ts --source",
    "harvest:schedule": "tsx src/harvester/scheduler.ts",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "tsx src/db/migrate.ts",
    "db:push": "drizzle-kit push",
    "db:studio": "drizzle-kit studio",
    "test": "vitest",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@fastify/cors": "^10.0.2",
    "@fastify/swagger": "^9.4.2",
    "@fastify/swagger-ui": "^5.2.1",
    "@turf/bbox": "^7.2.0",
    "croner": "^9.0.0",
    "drizzle-orm": "^0.38.4",
    "fast-xml-parser": "^5.0.8",
    "fastify": "^5.2.1",
    "pino": "^9.6.0",
    "postgres": "^3.4.5",
    "proj4": "^2.15.0",
    "yaml": "^2.7.0"
  },
  "devDependencies": {
    "@types/node": "^22.12.0",
    "drizzle-kit": "^0.30.4",
    "tsx": "^4.19.0",
    "typescript": "^5.7.0",
    "vitest": "^3.0.0"
  }
}
